// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMINISTRATOR
  STOCK_MANAGER
  BILLER
}

enum BillType {
  GST_BILL
  ESTIMATE_BILL
  SHOP_TO_SHOP_BILL
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  name      String
  role      UserRole
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bills     Bill[]
  stockLogs StockLog[]
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  address   String?
  gstin     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bills Bill[]
}

model Product {
  id          String   @id @default(cuid())
  hsnCode     String   @unique
  name        String
  description String?
  unit        String   @default("PCS")
  gstRate     Float    @default(18)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stock        Stock?
  billItems    BillItem[]
  stockLogs    StockLog[]
}

model Stock {
  id               String   @id @default(cuid())
  productId        String   @unique
  currentQuantity  Float    @default(0)
  reorderLevel     Float    @default(10)
  lastPurchaseRate Float?
  updatedAt        DateTime @updatedAt

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Bill {
  id           String   @id @default(cuid())
  billNumber   String   @unique
  billType     BillType
  customerId   String
  userId       String
  date         DateTime @default(now())
  subtotal     Float
  taxAmount    Float
  discount     Float    @default(0)
  grandTotal   Float
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer  Customer   @relation(fields: [customerId], references: [id])
  user      User       @relation(fields: [userId], references: [id])
  billItems BillItem[]

  @@index([date])
  @@index([billType])
}

model BillItem {
  id        String   @id @default(cuid())
  billId    String
  productId String
  quantity  Float
  rate      Float
  taxRate   Float
  taxAmount Float
  amount    Float
  createdAt DateTime @default(now())

  bill    Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
}

model StockLog {
  id          String   @id @default(cuid())
  productId   String
  userId      String
  type        String // "ADD", "REMOVE", "ADJUST", "SALE"
  quantity    Float
  beforeQty   Float
  afterQty    Float
  rate        Float?
  notes       String?
  createdAt   DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([createdAt])
}

model Settings {
  id    String @id @default(cuid())
  key   String @unique
  value String
}
